# MonkeyCode 认证配置

# 登录模式: user (普通用户) 或 team (团队管理员)
# 普通用户 → Cookie: monkeycode_ai_session
# 团队管理员 → Cookie: monkeycode_ai_team_session
MONKEYCODE_LOGIN_MODE=user

# 方式1: 使用邮箱和密码（密码以明文发送，HTTPS 加密传输）
# 注意：密码登录需要 captcha_token，自动化场景建议使用方式2
MONKEYCODE_EMAIL=
MONKEYCODE_PASSWORD=

# 方式2: 手动设置 Session Cookie（推荐，绕过验证码）
# 获取方式：浏览器登录后从 DevTools → Application → Cookies → monkeycode_ai_session
MONKEYCODE_SESSION_COOKIE=

# MonkeyCode 后端地址
MONKEYCODE_BASE_URL=https://monkeycode-ai.com

# 代理服务端口
PROXY_PORT=9090

# ========== 任务配置 ==========

# 宿主机 ID（public_host 为公共主机，免费用户使用）
MONKEYCODE_HOST_ID=public_host

# VM 镜像 ID（必填！）
# 获取方式：浏览器登录后创建一个任务，在 DevTools → Network 中找到
# POST /api/v1/users/tasks 请求体中的 image_id 字段
MONKEYCODE_IMAGE_ID=

# ========== 号池配置（可选） ==========

# 号池配置文件路径（JSON 格式的账号数组）
# ACCOUNT_POOL_FILE=./accounts.json
