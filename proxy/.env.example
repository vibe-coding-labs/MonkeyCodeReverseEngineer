# MonkeyCode 认证配置

# 登录模式: user (普通用户) 或 team (团队管理员)
# 普通用户 → Cookie: sl-session
# 团队管理员 → Cookie: monkeycode_ai_team_session
MONKEYCODE_LOGIN_MODE=user

# 方式1: 使用邮箱和密码（密码会自动 MD5 哈希）
# 注意：密码登录需要 captcha_token，自动化场景建议使用方式3
MONKEYCODE_EMAIL=
MONKEYCODE_PASSWORD=

# 方式2: 直接提供 MD5 哈希后的密码
# MONKEYCODE_PASSWORD_HASH=

# 方式3: 手动设置 Session Cookie（推荐，绕过验证码）
# 获取方式：浏览器登录后从 DevTools → Application → Cookies → sl-session
MONKEYCODE_SESSION_COOKIE=

# MonkeyCode 后端地址
MONKEYCODE_BASE_URL=https://monkeycode-ai.com

# 代理服务端口
PROXY_PORT=9090
