# MonkeyCode 认证配置
# 方式1: 使用用户名和密码（密码会自动 MD5 哈希）
MONKEYCODE_USERNAME=
MONKEYCODE_PASSWORD=

# 方式2: 直接提供 MD5 哈希后的密码
# MONKEYCODE_PASSWORD_HASH=

# 方式3: 手动设置 Session Cookie（通过 POST /admin/session）
# 获取方式：浏览器登录后从 Cookie 中复制 monkeycode_ai_session 的值

# MonkeyCode 后端地址
MONKEYCODE_BASE_URL=https://monkeycode-ai.com

# 代理服务端口
PROXY_PORT=9090
