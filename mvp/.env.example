# MonkeyCode 连接配置
MONKEYCODE_BASE_URL=https://monkeycode-ai.com

# 登录模式: user (普通用户) 或 team (团队管理员)
# 普通用户 → Cookie: sl-session
# 团队管理员 → Cookie: monkeycode_ai_team_session
MONKEYCODE_LOGIN_MODE=user

# 认证方式1: 邮箱密码登录（需要验证码）
MONKEYCODE_EMAIL=
MONKEYCODE_PASSWORD=
# MONKEYCODE_PASSWORD_HASH=  # 可选：直接提供 MD5 哈希，跳过明文密码
# MONKEYCODE_CAPTCHA_TOKEN=  # 可选：手动提供验证码 token

# 认证方式2: 直接使用 Session Cookie（推荐，绕过验证码）
# 获取方法: 浏览器登录后，DevTools → Application → Cookies → sl-session
MONKEYCODE_SESSION_COOKIE=

# 代理配置
PROXY_PORT=9090
